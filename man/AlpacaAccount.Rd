  "qty": "5",
  "filled_qty": "0",
  "type": "market",
  "side": "sell",
  "time_in_force": "day",
  "status": "pending_new"
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaAccount$close_position(symbol_or_id, qty = NULL, percentage = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol_or_id}}{(scalar<character>) ticker symbol or asset UUID.}

\item{\code{qty}}{(scalar<numeric> | NULL) number of shares to close. Mutually
exclusive with \code{percentage}.}

