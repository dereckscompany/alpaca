\subsection{Method \code{get_portfolio_history()}}{
Get Portfolio History

Retrieves the portfolio value history as a time series.
\subsection{API Endpoint}{

\verb{GET https://paper-api.alpaca.markets/v2/account/portfolio/history}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/getaccountportfoliohistory-1}{Portfolio History}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/account/portfolio/history?period=1M&timeframe=1D'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "timestamp": [1704067200, 1704153600, 1704240000],
  "equity": [100000.0, 100150.5, 99800.25],
  "profit_loss": [0.0, 150.5, -200.25],
  "profit_loss_pct": [0.0, 0.001505, -0.002],
  "base_value": 100000.0,
  "timeframe": "1D"
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaAccount$get_portfolio_history(
  period = NULL,
  timeframe = NULL,
  start = NULL,
  end = NULL,
  intraday_reporting = NULL,
  pnl_reset = NULL,
  date_start = NULL,
  date_end = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{period}}{(scalar<character> | NULL) time period for the history.
Examples: \code{"1D"}, \code{"1W"}, \code{"1M"}, \code{"3M"}, \code{"1A"}, \code{"all"}. Mutually
exclusive with providing both \code{start} and \code{end}.}

\item{\code{timeframe}}{(scalar<character> | NULL) resolution of the time series:
\code{"1Min"}, \code{"5Min"}, \code{"15Min"}, \code{"1H"}, \code{"1D"}.}

\item{\code{start}}{(scalar<character> | NULL) start timestamp in RFC3339 format.
Defaults to \code{end} minus \code{period}.}

\item{\code{end}}{(scalar<character> | NULL) end timestamp in RFC3339 format.}

\item{\code{intraday_reporting}}{(scalar<character> | NULL) \code{"market_hours"}
(default), \code{"extended_hours"}, or \code{"continuous"} (for 24/7 crypto
charts).}

\item{\code{pnl_reset}}{(scalar<character> | NULL) \code{"per_day"} (default) or
\code{"no_reset"}. Set to \code{"no_reset"} for continuous crypto PnL.}

\item{\code{date_start}}{(scalar<character> | NULL) deprecated alias for \code{start}.
Earlier releases used this name but it was silently ignored by the API.
Now forwarded to \code{start} with a deprecation warning. Will be removed in
a future release.}

\item{\code{date_end}}{(scalar<character> | NULL) deprecated alias for \code{end}.
Same notes as \code{date_start}.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(PortfolioHistory | promise<PortfolioHistory>) the portfolio
history. Columns: \code{timestamp} (POSIXct, UTC), \code{equity} (numeric),
\code{profit_loss} (numeric) and \code{profit_loss_pct} (numeric).
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
acct <- AlpacaAccount$new()
history <- acct$get_portfolio_history(period = "1M", timeframe = "1D")
print(history)
}
}
\if{html}{\out{</div>}}

}

}
