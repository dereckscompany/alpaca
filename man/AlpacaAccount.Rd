\subsection{Method \code{get_activities()}}{
Get Account Activities

Retrieves account activity history across all activity types. Activities
include order fills, dividends, transfers, and other events.
\subsection{API Endpoint}{

\verb{GET https://paper-api.alpaca.markets/v2/account/activities}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/getaccountactivities-2}{Account Activities}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/account/activities?activity_types=FILL&direction=desc&page_size=10'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{[
  \{
    "id": "20260310120000000::b3d29c1a-7e5f-4a2b-9c1d-8e7f6a5b4c3d",
    "activity_type": "FILL",
    "symbol": "AAPL",
    "side": "buy",
    "qty": "10",
    "price": "187.25",
    "cum_qty": "10",
    "leaves_qty": "0",
    "type": "fill",
    "transaction_time": "2026-03-10T12:00:00.000Z",
    "order_id": "61e69015-8549-4bab-b63c-cc230e7e2e8b",
    "order_status": "filled"
  \}
]
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaAccount$get_activities(
  activity_types = NULL,
  date = NULL,
  until = NULL,
  after = NULL,
  direction = NULL,
  page_size = NULL,
  page_token = NULL,
  category = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{activity_types}}{(scalar<character> | NULL) comma-separated activity
types to filter (e.g., \code{"FILL"}, \code{"DIV"}, \code{"TRANS"}). See Alpaca docs
for full list. Mutually exclusive with \code{category}.}

\item{\code{date}}{(scalar<character> | NULL) filter to a specific date
(\code{"YYYY-MM-DD"}).}

\item{\code{until}}{(scalar<character> | NULL) only activities before this
timestamp.}

\item{\code{after}}{(scalar<character> | NULL) only activities after this
timestamp.}

\item{\code{direction}}{(scalar<character> | NULL) \code{"asc"} or \code{"desc"}.}

\item{\code{page_size}}{(scalar<count in [1, 101[> | NULL) max results per page.
Alpaca caps this at \strong{100} for \verb{/v2/account/activities}; values above
100 return HTTP 422 server-side. This method validates the cap up-front
and \code{abort()}s with a clear message rather than letting the vendor
error leak through. Must be a single non-NA integerish value when
provided. Default \code{NULL} lets Alpaca pick its server-side default
(currently 100).}

\item{\code{page_token}}{(scalar<character> | NULL) cursor for the next page. For
activities this is the \strong{\code{id} of the last row from the previous page}
(Alpaca's activity IDs are sortable cursors, not opaque tokens). See the
"Pagination" section below.}

\item{\code{category}}{(scalar<character> | NULL) broad category filter:
\code{"trade_activity"} or \code{"non_trade_activity"}. Mutually exclusive with
\code{activity_types}.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Activity | promise<Activity>) the activities. Columns beyond the
guaranteed \code{Activity} set vary by activity type. \code{id} is the per-activity
cursor used for paging (see "Pagination"). An empty response returns a
zero-row table carrying the \code{Activity} columns.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
acct <- AlpacaAccount$new()
activities <- acct$get_activities(activity_types = "FILL")
print(activities)
}
}
\if{html}{\out{</div>}}

}

}
