\subsection{Method \code{add_watchlist()}}{
Create a Watchlist

Creates a new watchlist with an optional initial set of symbols.
\subsection{API Endpoint}{

\verb{POST https://paper-api.alpaca.markets/v2/watchlists}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/postwatchlist-1}{Create Watchlist}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -X POST -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  -H "Content-Type: application/json" \\
  -d '\{"name": "My Tech Stocks", "symbols": ["AAPL", "MSFT", "GOOGL"]\}' \\
  'https://paper-api.alpaca.markets/v2/watchlists'
}\if{html}{\out{</div>}}
}

\subsection{JSON Request}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "name": "My Tech Stocks",
  "symbols": ["AAPL", "MSFT", "GOOGL"]
\}
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "id": "d7e8f9a0-b1c2-3456-7890-abcdef123456",
  "account_id": "e6fe16f3-64a4-4921-8928-cadf02f92f98",
  "name": "My Tech Stocks",
  "created_at": "2026-03-10T15:00:00Z",
  "updated_at": "2026-03-10T15:00:00Z",
  "assets": [
    \{"id": "904837e3-3b76-47ec-b432-046db621571b", "symbol": "AAPL", "name": "Apple Inc."\},
    \{"id": "b2e3f4a5-c6d7-8901-2345-6789abcdef01", "symbol": "MSFT", "name": "Microsoft Corporation"\},
    \{"id": "c3d4e5f6-a7b8-9012-3456-789abcdef012", "symbol": "GOOGL", "name": "Alphabet Inc."\}
  ]
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaAccount$add_watchlist(name, symbols = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{name}}{(scalar<character>) watchlist name.}

\item{\code{symbols}}{(character | NULL) initial symbols (e.g.,
\code{c("AAPL", "MSFT")}).}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Watchlist | promise<Watchlist>) the same long-format shape as
\code{get_watchlist()}: one row per asset, with watchlist metadata (\code{id},
\code{account_id}, \code{name}, \code{created_at}, \code{updated_at}) replicated and asset
columns prefixed \code{asset_} (\code{asset_id}, \code{asset_symbol}, \code{asset_name},
\code{asset_attributes}, ...). A watchlist created with no symbols returns
one row with asset columns set to \code{NA}.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
acct <- AlpacaAccount$new()
wl <- acct$add_watchlist("My Tech Stocks", symbols = c("AAPL", "MSFT", "GOOGL"))
print(wl)
}
}
\if{html}{\out{</div>}}

}

}
