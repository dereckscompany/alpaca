\subsection{Method \code{cancel_watchlist_symbol()}}{
Remove Symbol from Watchlist

Removes a single symbol from a watchlist.
\subsection{API Endpoint}{

\verb{DELETE https://paper-api.alpaca.markets/v2/watchlists/\{watchlist_id\}/\{symbol\}}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/removeassetfromwatchlist-1}{Remove Symbol from Watchlist}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -X DELETE -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/watchlists/f5a6b7c8-d9e0-1234-5678-9abcdef01234/AAPL'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

The API returns \verb{204 No Content} on success. This method returns a
confirmation \code{data.table}:

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "watchlist_id": "f5a6b7c8-d9e0-1234-5678-9abcdef01234",
  "symbol": "AAPL",
  "status": "removed"
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaAccount$cancel_watchlist_symbol(watchlist_id, symbol)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{watchlist_id}}{(scalar<character>) watchlist UUID.}

\item{\code{symbol}}{(scalar<character>) ticker symbol to remove.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(data.table | promise<data.table>) the result. When the API
returns the updated watchlist, a single row with watchlist details. On
204 No Content, a single confirmation row with \code{watchlist_id}
(character, the watchlist UUID), \code{symbol} (character, the removed ticker
symbol) and \code{status} (character, \code{"removed"}).
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
acct <- AlpacaAccount$new()
acct$cancel_watchlist_symbol("some-uuid", "AAPL")
}
}
\if{html}{\out{</div>}}

}

}
