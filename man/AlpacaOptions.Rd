\subsection{Method \code{get_option_snapshot()}}{
Get Option Snapshot by Symbol

Retrieves a real-time snapshot for a single options contract.
\subsection{API Endpoint}{

\verb{GET https://data.alpaca.markets/v1beta1/options/snapshots/\{symbol\}}
}

\subsection{Official Documentation}{
\itemize{
\item \href{https://docs.alpaca.markets/us/reference/optionsnapshots}{Option Snapshot}
Verified: 2026-05-21
}

Note: Alpaca no longer documents a per-symbol snapshot endpoint; the URL
\verb{/v1beta1/options/snapshots/\{symbol\}} is the underlying-chain endpoint
(see \code{get_option_chain()}). For a true single-contract snapshot, prefer
\code{get_option_snapshots(symbols = "AAPL250620C00200000")}.
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://data.alpaca.markets/v1beta1/options/snapshots/AAPL250620C00200000'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "latestTrade": \{
    "t": "2025-03-07T20:58:45.987654Z",
    "p": 12.35,
    "s": 3,
    "x": "C",
    "c": ["a"]
  \},
  "latestQuote": \{
    "t": "2025-03-07T20:59:58.123456Z",
    "ax": "C",
    "ap": 12.50,
    "as": 15,
    "bx": "P",
    "bp": 12.30,
    "bs": 22,
    "c": "A"
  \},
  "impliedVolatility": 0.2856,
  "greeks": \{
    "delta": 0.5423,
    "gamma": 0.0187,
    "theta": -0.0842,
    "vega": 0.3215,
    "rho": 0.1456
  \}
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaOptions$get_option_snapshot(symbol, feed = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{symbol}}{Character; OCC option symbol.}

\item{\code{feed}}{Character or NULL; data feed.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
\code{data.table} (or \verb{promise<data.table>} if \code{async = TRUE}) with
the same shape as \code{get_option_chain()} — one row per contract in
the chain rooted at \code{symbol}. Despite the legacy name, this is
\strong{not} a single-contract snapshot; for that, use
\code{get_option_snapshots(symbols = "<OCC>")}.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
opts <- AlpacaOptions$new()
snap <- opts$get_option_snapshot("AAPL240621C00200000")
print(snap)
}
}
\if{html}{\out{</div>}}

}

}
