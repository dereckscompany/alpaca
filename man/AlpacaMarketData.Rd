\subsection{Method \code{get_corporate_actions()}}{
Get Corporate Action Announcements

Retrieves announcements for corporate actions such as dividends, mergers,
spinoffs, and stock splits. Essential for production trading systems that
need to handle position adjustments.
\subsection{API Endpoint}{

\verb{GET https://paper-api.alpaca.markets/v2/corporate_actions/announcements}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/get-v2-corporate_actions-announcements-1}{Corporate Actions}
Verified: 2026-05-21

Note: as of 2026-05, the \verb{/v2/corporate_actions/announcements} endpoint is
marked DEPRECATED by Alpaca. It still works and the wrapper still calls
it, but Alpaca recommends migrating to the newer corporate-actions
market-data endpoint (\verb{/v1beta1/corporate-actions}). Migration is tracked
as a follow-up.
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/corporate_actions/announcements?ca_types=dividend&since=2024-01-01&until=2024-03-31'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{[
  \{
    "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "corporate_action_id": "DIV_AAPL_2024Q1",
    "ca_type": "dividend",
    "ca_sub_type": "cash",
    "initiating_symbol": "AAPL",
    "target_symbol": "AAPL",
    "declaration_date": "2024-02-01",
    "ex_date": "2024-02-09",
    "record_date": "2024-02-12",
    "payable_date": "2024-02-15",
    "cash": "0.24",
    "old_rate": "1",
    "new_rate": "1"
  \}
]
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaMarketData$get_corporate_actions(
  ca_types,
  since,
  until,
  symbol = NULL,
  cusip = NULL,
  date_type = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{ca_types}}{(scalar<character>) comma-separated corporate action
types. Valid values: \code{"dividend"}, \code{"merger"}, \code{"spinoff"}, \code{"split"}.}

\item{\code{since}}{(scalar<character>) start date (\code{"YYYY-MM-DD"}). Required.}

\item{\code{until}}{(scalar<character>) end date (\code{"YYYY-MM-DD"}). Required.}

\item{\code{symbol}}{(scalar<character> | NULL) filter by ticker symbol.}

\item{\code{cusip}}{(scalar<character> | NULL) filter by CUSIP.}

\item{\code{date_type}}{(scalar<character> | NULL) which date field \code{since}/\code{until}
refer to. Alpaca's documented / SDK values are \code{"declaration_date"},
\code{"ex_date"}, \code{"record_date"}, \code{"payable_date"} (default server-side:
\code{"ex_date"}). Validated client-side; invalid values abort before the
request.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(CorporateAction | promise<CorporateAction>) the announcements.
Columns: \code{id}, \code{corporate_action_id}, \code{ca_type}, \code{ca_sub_type},
\code{initiating_symbol}, \code{target_symbol}, \code{cash}, \code{old_rate}, \code{new_rate}
(character); \code{declaration_date}, \code{ex_date}, \code{record_date},
\code{payable_date} (Date).
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
market <- AlpacaMarketData$new()

# Get all AAPL dividends in 2024
divs <- market$get_corporate_actions(
  ca_types = "dividend", since = "2024-01-01", until = "2024-12-31",
  symbol = "AAPL"
)
print(divs)

# Get all stock splits
splits <- market$get_corporate_actions(
  ca_types = "split", since = "2024-01-01", until = "2024-12-31"
)
}
}
\if{html}{\out{</div>}}

}

}
