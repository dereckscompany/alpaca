  ],
  "losers": [
    \{"symbol": "MRNA", "percent_change": -6.12, "change": -6.80, "price": 104.30\},
    \{"symbol": "ENPH", "percent_change": -5.45, "change": -6.10, "price": 105.80\},
    \{"symbol": "COIN", "percent_change": -4.98, "change": -7.50, "price": 143.10\}
  ],
  "market_type": "stocks",
  "last_updated": "2024-01-15T20:00:00Z"
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaMarketData$get_movers(market_type = "stocks", top = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{market_type}}{(scalar<character>) \code{"stocks"} (default) or \code{"crypto"}.}

\item{\code{top}}{(scalar<count in [1, Inf[> | NULL) number of results per
direction (default 10).}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Movers | promise<Movers>) the movers. Columns: \code{symbol}
(character); \code{percent_change}, \code{change}, \code{price} (numeric); plus a
\code{direction} column (\code{"gainer"} / \code{"loser"}).
}
