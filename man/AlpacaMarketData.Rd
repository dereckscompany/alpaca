\subsection{Method \code{get_calendar()}}{
Get Market Calendar

Retrieves the market calendar showing trading days and hours.
Includes early closure information.
\subsection{API Endpoint}{

\verb{GET https://paper-api.alpaca.markets/v2/calendar}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/legacycalendar}{Calendar}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/calendar?start=2024-01-01&end=2024-01-05'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{[
  \{"date": "2024-01-02", "open": "09:30", "close": "16:00", "session_open": "0700", "session_close": "1900", "settlement_date": "2024-01-04"\},
  \{"date": "2024-01-03", "open": "09:30", "close": "16:00", "session_open": "0700", "session_close": "1900", "settlement_date": "2024-01-05"\},
  \{"date": "2024-01-04", "open": "09:30", "close": "16:00", "session_open": "0700", "session_close": "1900", "settlement_date": "2024-01-08"\},
  \{"date": "2024-01-05", "open": "09:30", "close": "16:00", "session_open": "0700", "session_close": "1900", "settlement_date": "2024-01-09"\}
]
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaMarketData$get_calendar(start = NULL, end = NULL, date_type = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{start}}{(scalar<character> | NULL) start date (\code{"YYYY-MM-DD"}).}

\item{\code{end}}{(scalar<character> | NULL) end date (\code{"YYYY-MM-DD"}).}

\item{\code{date_type}}{(scalar<character> | NULL) one of \code{"TRADING"} or
\code{"SETTLEMENT"}. Determines whether \code{start}/\code{end} are interpreted as
trading dates (default) or settlement dates.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(Calendar | promise<Calendar>) the calendar. Columns: \code{date}
and \code{settlement_date} (Date); \code{open}, \code{close}, \code{session_open},
