\subsection{Method \code{get_clock()}}{
Get Market Clock

Retrieves the current market clock including whether the market is
open and the next open/close times.
\subsection{API Endpoint}{

\verb{GET https://paper-api.alpaca.markets/v2/clock}
}

\subsection{Official Documentation}{

\href{https://docs.alpaca.markets/us/reference/legacyclock}{Clock}
Verified: 2026-05-21
}

\subsection{curl}{

\if{html}{\out{<div class="sourceCode">}}\preformatted{curl -H "APCA-API-KEY-ID: $KEY" -H "APCA-API-SECRET-KEY: $SECRET" \\
  'https://paper-api.alpaca.markets/v2/clock'
}\if{html}{\out{</div>}}
}

\subsection{JSON Response}{

\if{html}{\out{<div class="sourceCode json">}}\preformatted{\{
  "timestamp": "2024-01-15T14:30:00.000-05:00",
  "is_open": true,
  "next_open": "2024-01-16T09:30:00-05:00",
  "next_close": "2024-01-15T16:00:00-05:00"
\}
}\if{html}{\out{</div>}}
}
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{AlpacaMarketData$get_clock()}\if{html}{\out{</div>}}
}

\subsection{Returns}{
(Clock | promise<Clock>) the clock. Columns:
\code{timestamp}, \code{next_open}, \code{next_close} (POSIXct, \code{America/New_York}) and
\code{is_open} (logical).

The Alpaca clock endpoint returns ISO-8601 timestamps with an
explicit offset; we parse the instant exactly and display it in
\code{America/New_York} for consistency with \code{get_calendar()}. Use
\code{lubridate::with_tz()} to view in another timezone.
}
\subsection{Examples}{
\if{html}{\out{<div class="r example copy">}}
\preformatted{\dontrun{
market <- AlpacaMarketData$new()
clock <- market$get_clock()
cat("Market open:", clock$is_open, "\n")
}
}
\if{html}{\out{</div>}}

}

}
